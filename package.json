{
  "name": "sawdust-and-strings",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://dbaileyfam.github.io/sawdustandstrings/",
  "scripts": {
    "dev": "vite index.dev.html",
    "build": "tsc -b && vite build",
    "postbuild": "mv dist/index.dev.html dist/index.html && cp dist/index.html dist/404.html",
    "build:pages": "VITE_BASE_PATH=/sawdustandstrings/ npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:pages": "node scripts/verify-pages.mjs",
    "predeploy": "npm run build:pages",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
